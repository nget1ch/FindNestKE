# DATABASE
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# SERVER CONFIGURATION
PORT=3000
NODE_ENV=development

# JWT SECURITY (Set these to strong random strings in production)
JWT_SECRET=your_jwt_access_secret_at_least_32_characters
JWT_REFRESH_SECRET=your_jwt_refresh_secret_at_least_32_characters

# CLOUDINARY MEDIA MANAGER
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# KRA FINTECH SYNC & COMPLIANCE
KRA_PIN=A000000000X
KRA_CONSUMER_KEY=your_kra_apigee_consumer_key
KRA_CONSUMER_SECRET=your_kra_apigee_consumer_secret
KRA_TCC_SANDBOX_URL=https://sbx.kra.go.ke/v1/kra-tcc/validate

# M-PESA DARAJA GATEWAY
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-domain.serveo.net/api/payments/mpesa/callback

# STRIPE GATEWAY (Optional for card payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
